# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="******localhost:5432/chequealo"
DATABASE_DIRECT_URL="******localhost:5432/chequealo"

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth (Auth.js / NextAuth) ──────────────────────────────────────────────
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── AI Providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
GROQ_API_KEY=""

# Default AI provider: openai | anthropic | gemini | groq
DEFAULT_AI_PROVIDER="openai"

# ─── Search Providers ────────────────────────────────────────────────────────
SERPER_API_KEY=""
BRAVE_SEARCH_API_KEY=""
TAVILY_API_KEY=""

# Default search provider: serper | brave | tavily
DEFAULT_SEARCH_PROVIDER="serper"

# ─── Storage (S3-compatible) ─────────────────────────────────────────────────
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="chequealo-assets"

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
APP_ENV="development"   # development | staging | production

# ─── Netlify (set these in the Netlify UI / environment variables) ────────────
# NEXTAUTH_URL is your Netlify deploy URL in production, e.g.:
#   NEXTAUTH_URL="https://www.chequealo.ai"
# TURBO_TOKEN and TURBO_TEAM enable Turborepo Remote Cache on Netlify:
#   TURBO_TOKEN=""
#   TURBO_TEAM=""

# ─── Observability ──────────────────────────────────────────────────────────
SENTRY_DSN=""
OTEL_EXPORTER_OTLP_ENDPOINT=""
LOG_LEVEL="info"        # debug | info | warn | error
